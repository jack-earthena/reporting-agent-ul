# Port (Railway sets PORT automatically)
PORT=3081

# Path to CSV data folder (default: ./data when not set)
# DATA_DIR=./data

# CORS: comma-separated allowed origins for browser requests
# Lovable app URLs are included by default; add more if needed
ALLOWED_ORIGINS=https://id-preview--5a62631f-7f03-4dd4-97d6-f5f00fac202e.lovable.app,https://5a62631f-7f03-4dd4-97d6-f5f00fac202e.lovable.app

# Rate limit: max report requests per IP per minute
RATE_LIMIT=20

# CSV cache TTL in milliseconds (default: 1 hour)
# CACHE_TTL_MS=3600000
